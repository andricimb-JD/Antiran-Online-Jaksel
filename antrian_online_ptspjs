<!doctype html>
<html lang="id" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Smart Queue - Supabase Edition</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  
  <!-- Supabase SDK -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    .font-numeric { font-family: 'Space Grotesk', sans-serif; }
    .custom-scroll::-webkit-scrollbar { width: 6px; }
    .custom-scroll::-webkit-scrollbar-track { background: #f1f5f9; }
    .custom-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
  </style>
 </head>
 <body class="h-full bg-slate-50 text-slate-800">
  <div id="app-wrapper" class="h-full w-full overflow-auto flex flex-col">
   <header id="app-header" class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
     <div class="flex items-center space-x-3">
      <div class="bg-blue-600 text-white p-2.5 rounded-xl shadow-md shadow-blue-200">
       <i data-lucide="database" class="w-5 h-5"></i>
      </div>
      <div>
       <h1 id="header-title" class="text-md font-bold text-slate-900 tracking-tight leading-none">SmartQueue Selatan</h1>
       <span id="header-subtitle" class="text-[10px] text-slate-500 font-semibold tracking-wider uppercase">Didukung oleh Supabase</span>
      </div>
     </div>
     <div class="flex items-center space-x-3 text-sm">
      <div class="hidden md:flex flex-col text-right mr-3 border-r pr-4 border-slate-200">
       <span id="live-date" class="text-[10px] text-slate-400 font-bold uppercase">Memuat...</span> 
       <span id="live-time" class="text-xs font-bold text-slate-700 font-numeric">--:-- WIB</span>
      </div>
      <div id="user-info" class="hidden flex items-center space-x-2 bg-indigo-50 text-indigo-700 px-3 py-1.5 rounded-full border border-indigo-200 font-medium">
       <i data-lucide="user" class="w-3 h-3"></i> 
       <span id="user-display" class="text-xs font-semibold">-</span> 
       <button onclick="logout()" class="ml-2 text-indigo-600 hover:text-indigo-800 font-bold text-xs">Keluar</button>
      </div>
      <div id="db-badge" class="flex items-center space-x-2 bg-amber-50 text-amber-700 px-3 py-1.5 rounded-full border border-amber-200 font-medium transition-colors">
       <span id="db-indicator" class="w-2 h-2 rounded-full bg-amber-500 animate-pulse"></span> 
       <span id="db-status" class="text-xs">Mode Lokal</span>
      </div>
     </div>
    </div>
   </header>

   <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Toast -->
    <div id="toast-container" class="fixed top-20 right-4 z-50 space-y-2 pointer-events-none"></div>

    <!-- PORTAL VIEW -->
    <div id="view-portal" class="max-w-4xl mx-auto py-12">
     <div class="text-center mb-12">
      <h2 class="text-4xl font-extrabold text-slate-900 tracking-tight">Portal Layanan Mandiri</h2>
      <p class="mt-3 text-lg text-slate-600">Silakan pilih jenis modul halaman di bawah ini.</p>
     </div>
     <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <button onclick="switchView('register')" class="group bg-white p-8 rounded-2xl border border-slate-200 hover:border-blue-500 hover:shadow-xl transition-all text-left flex flex-col justify-between h-64">
       <div class="space-y-4">
        <div class="bg-blue-50 text-blue-600 p-4 rounded-2xl w-14 h-14 flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-colors">
         <i data-lucide="ticket" class="w-6 h-6"></i>
        </div>
        <div>
         <h3 class="text-xl font-bold text-slate-900">Ambil Antrian</h3>
         <p class="text-slate-500 mt-2 text-sm leading-relaxed">Registrasi mandiri dan cetak nomor antrian.</p>
        </div>
       </div>
      </button> 
      <button onclick="switchView('monitor')" class="group bg-white p-8 rounded-2xl border border-slate-200 hover:border-indigo-500 hover:shadow-xl transition-all text-left flex flex-col justify-between h-64">
       <div class="space-y-4">
        <div class="bg-indigo-50 text-indigo-600 p-4 rounded-2xl w-14 h-14 flex items-center justify-center group-hover:bg-indigo-600 group-hover:text-white transition-colors">
         <i data-lucide="monitor" class="w-6 h-6"></i>
        </div>
        <div>
         <h3 class="text-xl font-bold text-slate-900">Monitor Layar</h3>
         <p class="text-slate-500 mt-2 text-sm leading-relaxed">Papan tampilan panggilan nomor antrian loket.</p>
        </div>
       </div>
      </button> 
      <button onclick="switchView('admin')" class="group bg-white p-8 rounded-2xl border border-slate-200 hover:border-emerald-500 hover:shadow-xl transition-all text-left flex flex-col justify-between h-64">
       <div class="space-y-4">
        <div class="bg-emerald-50 text-emerald-600 p-4 rounded-2xl w-14 h-14 flex items-center justify-center group-hover:bg-emerald-600 group-hover:text-white transition-colors">
         <i data-lucide="shield-check" class="w-6 h-6"></i>
        </div>
        <div>
         <h3 class="text-xl font-bold text-slate-900">Portal Petugas</h3>
         <p class="text-slate-500 mt-2 text-sm leading-relaxed">Kelola panggilan loket dan dashboard laporan.</p>
        </div>
       </div>
      </button>
     </div>
    </div>

    <!-- REGISTER VIEW -->
    <div id="view-register" class="hidden max-w-2xl mx-auto">
     <div class="mb-6">
      <button onclick="switchView('portal')" class="text-slate-500 hover:text-slate-800 flex items-center font-medium"> 
        <i data-lucide="arrow-left" class="w-4 h-4 mr-2"></i> Kembali ke Portal 
      </button>
     </div>
     <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
      <h2 class="text-2xl font-bold text-slate-900 mb-6">Ambil Nomor Antrian Anda</h2>
      <form id="queue-form" onsubmit="handleRegister(event)" class="space-y-5">
       <div>
        <label for="reg-name" class="block text-sm font-semibold text-slate-700 mb-2">Nama Pemohon <span class="text-red-500">*</span></label> 
        <input type="text" id="reg-name" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:outline-none" placeholder="Nama Lengkap">
       </div>
       <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
         <label for="reg-phone" class="block text-sm font-semibold text-slate-700 mb-2">No. Telepon <span class="text-red-500">*</span></label> 
         <input type="tel" id="reg-phone" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:outline-none" placeholder="08xxxxxxxxxx">
        </div>
        <div>
         <label for="reg-unit-wilayah" class="block text-sm font-semibold text-slate-700 mb-2">Tingkat Wilayah <span class="text-red-500">*</span></label> 
         <select id="reg-unit-wilayah" onchange="handleUnitWilayahChange()" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 bg-white focus:outline-none"> 
           <option value="">-- Pilih Wilayah --</option> 
           <option value="Kota">Tingkat Kota</option> 
           <option value="Kecamatan">Tingkat Kecamatan</option> 
           <option value="Kelurahan">Tingkat Kelurahan</option> 
         </select>
        </div>
       </div>
       <div id="wilayah-container" class="hidden grid grid-cols-1 md:grid-cols-2 gap-4 p-4 bg-slate-50 rounded-2xl border border-slate-200">
        <div id="kecamatan-box" class="hidden">
         <label for="reg-kecamatan" class="block text-xs font-bold text-slate-600 mb-2">Kecamatan</label> 
         <select id="reg-kecamatan" onchange="handleKecamatanChange()" class="w-full px-4 py-2.5 rounded-xl border bg-white focus:outline-none"><option value="">-- Pilih --</option></select>
        </div>
        <div id="kelurahan-box" class="hidden">
         <label for="reg-kelurahan" class="block text-xs font-bold text-slate-600 mb-2">Kelurahan</label> 
         <select id="reg-kelurahan" disabled class="w-full px-4 py-2.5 rounded-xl border bg-white focus:outline-none"><option value="">-- Pilih --</option></select>
        </div>
       </div>
       <div>
        <label for="reg-address-detail" class="block text-sm font-semibold text-slate-700 mb-2">Alamat Lengkap <span class="text-red-500">*</span></label> 
        <textarea id="reg-address-detail" required rows="3" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:outline-none" placeholder="Nama jalan, RT/RW, nomor gedung, dll."></textarea>
       </div>
       <div>
        <label for="reg-purpose" class="block text-sm font-semibold text-slate-700 mb-2">Jenis Layanan <span class="text-red-500">*</span></label> 
        <select id="reg-purpose" required class="w-full px-4 py-3 rounded-xl border bg-white focus:ring-2 focus:ring-blue-500 focus:outline-none"><option value="">-- Pilih Layanan --</option></select>
       </div>
       <button type="submit" id="btn-register" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl transition-all shadow-md flex justify-center items-center gap-2"> 
         <i data-lucide="printer" class="w-5 h-5"></i> Cetak Nomor Antrian 
       </button>
      </form>
     </div>
    </div>

    <!-- LOGIN MODAL -->
    <div id="login-modal" class="hidden fixed inset-0 bg-slate-900/60 flex items-center justify-center p-4 z-50">
     <div class="bg-white rounded-3xl p-8 w-full max-w-md relative shadow-2xl">
      <button onclick="closeLoginModal()" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
      <h3 class="text-xl font-bold text-center text-slate-900 mb-2">Portal Petugas</h3>
      <p class="text-xs text-slate-500 text-center mb-6">Masuk dengan akun Anda untuk mengelola antrian</p>
      <form onsubmit="handleLogin(event)" class="space-y-4">
       <div>
        <label for="login-username" class="block text-xs font-semibold text-slate-700 mb-1">Username</label> 
        <input type="text" id="login-username" required class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:outline-none text-sm" placeholder="Masukkan username">
       </div>
       <div>
        <label for="login-password" class="block text-xs font-semibold text-slate-700 mb-1">Password</label> 
        <input type="password" id="login-password" required class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:outline-none text-sm" placeholder="Masukkan password">
       </div>
       <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2.5 rounded-xl transition-all shadow-md text-sm">Masuk</button>
      </form>
      <div class="mt-4 p-3 bg-slate-50 rounded-lg border border-slate-200">
       <p class="text-[10px] font-semibold text-slate-600 mb-2">📝 Akun Demo bawaan:</p>
       <div class="space-y-1 text-[10px] text-slate-600 font-mono">
        <p><span class="bg-slate-200 px-1.5 py-0.5 rounded font-bold">admin</span> / <span class="bg-slate-200 px-1.5 py-0.5 rounded">admin123</span> (Role: Admin - MASTER)</p>
        <p><span class="bg-slate-200 px-1.5 py-0.5 rounded font-bold">tebet</span> / <span class="bg-slate-200 px-1.5 py-0.5 rounded">tebet123</span> (Role: User - Kec. Tebet)</p>
       </div>
      </div>
     </div>
    </div>

    <!-- MONITOR VIEW -->
    <div id="view-monitor" class="hidden">
     <div class="mb-6">
      <button onclick="switchView('portal')" class="text-slate-500 font-medium flex items-center"><i data-lucide="arrow-left" class="w-4 h-4 mr-2"></i> Kembali</button>
     </div>
     <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 space-y-6">
       <div class="bg-gradient-to-tr from-slate-900 to-indigo-950 rounded-3xl p-8 text-white shadow-xl">
        <span class="bg-indigo-500/20 text-indigo-300 px-3 py-1.5 rounded-full text-xs font-semibold uppercase">Panggilan Utama</span>
        <div class="mt-8 flex justify-between items-center">
         <div>
          <div id="mon-current-num" class="text-7xl md:text-8xl font-black font-numeric mt-1"> --- </div>
          <p id="mon-current-purpose" class="text-lg font-semibold mt-3 text-slate-300">-- Antrian Kosong --</p>
         </div>
         <div class="bg-white/10 p-6 rounded-2xl text-center min-w-[120px]">
          <span class="text-xs font-bold text-indigo-300">MENUJU LOKET</span><br>
          <span id="mon-current-counter" class="text-4xl font-extrabold mt-2 block">--</span>
         </div>
        </div>
       </div>
       <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-white border p-5 rounded-2xl text-center shadow-sm">
         <h4 class="text-xs font-bold text-slate-400 uppercase">Loket 1</h4>
         <div id="mon-num-l1" class="text-3xl font-extrabold font-numeric text-slate-800 mt-2"> -- </div>
         <span id="mon-purpose-l1" class="text-xs text-slate-500 block truncate mt-1">Kosong</span>
        </div>
        <div class="bg-white border p-5 rounded-2xl text-center shadow-sm">
         <h4 class="text-xs font-bold text-slate-400 uppercase">Loket 2</h4>
         <div id="mon-num-l2" class="text-3xl font-extrabold font-numeric text-slate-800 mt-2"> -- </div>
         <span id="mon-purpose-l2" class="text-xs text-slate-500 block truncate mt-1">Kosong</span>
        </div>
        <div class="bg-white border p-5 rounded-2xl text-center shadow-sm">
         <h4 class="text-xs font-bold text-slate-400 uppercase">Loket 3</h4>
         <div id="mon-num-l3" class="text-3xl font-extrabold font-numeric text-slate-800 mt-2"> -- </div>
         <span id="mon-purpose-l3" class="text-xs text-slate-500 block truncate mt-1">Kosong</span>
        </div>
       </div>
      </div>
      <div class="bg-white border rounded-3xl p-6 flex flex-col shadow-sm" style="height:420px">
       <h3 class="font-bold text-slate-900 flex justify-between items-center border-b pb-3">
         Daftar Tunggu <span id="mon-total-waiting" class="bg-blue-100 text-blue-700 px-2.5 py-1 rounded-full text-xs font-bold">0</span>
       </h3>
       <div id="mon-waiting-list" class="flex-grow overflow-y-auto mt-4 space-y-2 custom-scroll"></div>
      </div>
     </div>
    </div>

    <!-- ADMIN VIEW -->
    <div id="view-admin" class="hidden space-y-6">
     <div class="flex justify-between items-center pb-4 border-b">
      <div>
       <button onclick="switchView('portal')" class="text-slate-500 font-medium flex items-center mb-2"><i data-lucide="arrow-left" class="w-4 h-4 mr-2"></i> Kembali</button>
       <h2 class="text-2xl font-extrabold text-slate-900">Panel Operator Loket</h2>
       <div class="flex items-center space-x-2 mt-1">
         <span id="admin-role-badge" class="px-2 py-0.5 bg-blue-100 text-blue-800 rounded text-[10px] font-bold uppercase">-</span>
         <p id="admin-tenant-info" class="text-xs text-slate-500 font-semibold">Wilayah: -</p>
       </div>
      </div>
      <div class="flex gap-3">
       <select id="admin-select-counter" onchange="updateAdminView()" class="bg-white border px-3 py-2 rounded-xl text-sm font-semibold focus:outline-none"> 
         <option value="Loket 1">Loket 1</option> 
         <option value="Loket 2">Loket 2</option> 
         <option value="Loket 3">Loket 3</option> 
       </select> 
       <button onclick="switchView('report')" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-xl text-sm font-semibold"> 
         <i data-lucide="bar-chart-3" class="w-4 h-4 inline mr-1"></i> Laporan 
       </button>
      </div>
     </div>

     <!-- Admin Tab Navigation -->
     <div class="border-b border-slate-200">
       <nav class="flex space-x-6">
         <button onclick="switchAdminTab('panggilan')" id="tab-panggilan" class="border-b-2 border-blue-600 py-3 px-1 text-sm font-bold text-blue-600">
           Panggilan Antrean
         </button>
         <button onclick="switchAdminTab('layanan')" id="tab-layanan" class="border-b-2 border-transparent py-3 px-1 text-sm font-semibold text-slate-500 hover:text-slate-800">
           Kelola Layanan
         </button>
         <button onclick="switchAdminTab('users')" id="tab-users" class="hidden border-b-2 border-transparent py-3 px-1 text-sm font-semibold text-slate-500 hover:text-slate-800">
           Manajemen Pengguna (Admin Only)
         </button>
       </nav>
     </div>

     <!-- TAB CONTENT: PANGGILAN ANTREAN -->
     <div id="content-admin-panggilan" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-2 space-y-6">
       <div class="bg-white border rounded-3xl p-6 flex gap-6 shadow-sm items-center">
        <div class="bg-slate-50 border p-6 rounded-2xl text-center w-1/3">
         <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Aktif Melayani</span>
         <div id="admin-current-num" class="text-5xl font-black my-2 font-numeric text-blue-600"> --- </div>
         <span id="admin-current-purpose" class="text-[11px] bg-slate-200 text-slate-700 px-2 py-1 rounded-full block truncate">Belum ada panggilan</span>
        </div>
        <div class="space-y-3 flex-grow">
         <button onclick="callNextQueue()" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl shadow-lg shadow-blue-100">Panggil Antrian Berikutnya</button> 
         <button onclick="recallCurrentQueue()" class="w-full bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold py-3 rounded-xl transition-all">Panggil Ulang (Recall)</button>
        </div>
       </div>
       <div class="bg-white border rounded-3xl p-6 shadow-sm">
        <h3 class="font-bold text-slate-900 mb-4 flex justify-between items-center text-sm md:text-base">
          <span id="admin-table-title-area">Daftar Antrian Sesuai Wilayah Kerja Anda</span>
          <span id="admin-queue-count" class="bg-blue-100 text-blue-800 px-2.5 py-0.5 rounded-full text-xs font-bold">0</span>
        </h3>
        <div class="overflow-x-auto">
         <table class="w-full text-left text-sm">
          <thead class="border-b bg-slate-50">
           <tr class="text-slate-500 font-semibold">
            <th class="p-3">No</th>
            <th class="p-3">Nama</th>
            <th class="p-3">Layanan</th>
            <th class="p-3">Wilayah</th>
            <th class="p-3">Status</th>
            <th class="p-3 text-right">Aksi</th>
           </tr>
          </thead>
          <tbody id="admin-table-body" class="divide-y"></tbody>
         </table>
        </div>
       </div>
      </div>
      <div class="space-y-6">
       <!-- Card Status Operator -->
       <div class="bg-white border rounded-3xl p-6 shadow-sm">
        <h3 class="font-bold text-slate-900 mb-4 flex items-center gap-2">
          <i data-lucide="shield" class="w-5 h-5 text-indigo-600"></i> Informasi Petugas
        </h3>
        <div class="space-y-2 text-xs">
          <div class="flex justify-between py-2 border-b">
            <span class="text-slate-500">Nama Petugas</span>
            <span id="op-info-name" class="font-bold text-slate-800">-</span>
          </div>
          <div class="flex justify-between py-2 border-b">
            <span class="text-slate-500">Tingkat Wilayah</span>
            <span id="op-info-level" class="font-bold text-slate-800">-</span>
          </div>
          <div class="flex justify-between py-2 border-b">
            <span class="text-slate-500">Wilayah Tugas</span>
            <span id="op-info-area" class="font-bold text-slate-800">-</span>
          </div>
        </div>
       </div>
      </div>
     </div>

     <!-- TAB CONTENT: KELOLA LAYANAN -->
     <div id="content-admin-layanan" class="hidden max-w-2xl">
       <div class="bg-white border rounded-3xl p-6 shadow-sm">
        <h3 class="font-bold text-slate-900 mb-4">Kelola Jenis Layanan</h3>
        <form onsubmit="handleAddService(event)" class="space-y-3 mb-6">
         <input type="text" id="new-service-input" required class="w-full text-sm px-3 py-2 border rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none" placeholder="Nama Layanan Baru">
         <div class="flex gap-2">
          <input type="text" id="new-service-prefix" required maxlength="5" class="w-2/3 text-sm px-3 py-2 border rounded-xl uppercase focus:ring-2 focus:ring-blue-500 focus:outline-none" placeholder="Prefix (Cth: OSS)"> 
          <button type="submit" class="w-1/3 bg-emerald-600 text-white px-3 py-2 rounded-xl font-bold hover:bg-emerald-700 text-sm">Tambah</button>
         </div>
        </form>
        <div id="admin-services-list" class="space-y-2 max-h-72 overflow-y-auto custom-scroll"></div>
       </div>
     </div>

     <!-- TAB CONTENT: MANAJEMEN PENGGUNA (Admin Only) -->
     <div id="content-admin-users" class="hidden space-y-6">
       <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
         <div class="bg-white border rounded-3xl p-6 shadow-sm">
           <h3 class="font-bold text-slate-900 mb-4 flex items-center gap-2 text-md">
             <i data-lucide="user-plus" class="w-5 h-5 text-blue-600"></i> Tambah Petugas Baru
           </h3>
           <form onsubmit="handleCreateUser(event)" class="space-y-4">
             <div>
               <label for="u-display-name" class="block text-xs font-bold text-slate-600 mb-1">Nama Petugas</label>
