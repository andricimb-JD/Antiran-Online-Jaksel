  <script>
    /* =====================================================================
       KONFIGURASI SUPABASE (SQL Schema dilampirkan di bawah)
       ===================================================================== */
    // GANTI DENGAN KREDENSIAL SUPABASE ANDA
    const SUPABASE_URL = 'YOUR_SUPABASE_URL';
    const SUPABASE_KEY = 'YOUR_SUPABASE_ANON_KEY';
    
    // Auto-fallback: Jika API belum diisi, kita gunakan mode Local Storage.
    const isSupabaseActive = SUPABASE_URL.startsWith('http');
    let supabaseClient = null;

    if (isSupabaseActive) {
      supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
      document.getElementById('db-status').textContent = 'Supabase Terhubung';
      document.getElementById('db-badge').classList.replace('bg-amber-50', 'bg-emerald-50');
      document.getElementById('db-badge').classList.replace('text-amber-700', 'text-emerald-700');
      document.getElementById('db-badge').classList.replace('border-amber-200', 'border-emerald-200');
      document.getElementById('db-indicator').classList.replace('bg-amber-500', 'bg-emerald-500');
    }

    /* SKEMA SQL UNTUK SUPABASE (Jalankan di SQL Editor Supabase Anda):
       ---------------------------------------------------------------------
       create table queues (
         id uuid default uuid_generate_v4() primary key,
         queue_number text, timestamp timestamptz default now(),
         name text, phone text, unit_wilayah text, kecamatan text,
         kelurahan text, address_detail text, purpose text, status text, counter text
       );
       
       create table users (
         id uuid default uuid_generate_v4() primary key,
         username text unique, password text, role text, tenant text,
         display_name text, unit_wilayah text, kecamatan text, kelurahan text
       );
       
       create table services (
         id uuid default uuid_generate_v4() primary key,
         name text unique, prefix text
       );
    */

    // --- STATE ---
    let queueDatabase = [];
    let currentView = 'portal';
    let currentAdminTab = 'panggilan';
    let purposeChartInstance = null;
    let regionChartInstance = null;
    let currentUser = null;
    let currentTenant = null;

    // Default Fallback Database jika Supabase tidak aktif
    let usersDatabase = isSupabaseActive ? [] : JSON.parse(localStorage.getItem('sq_users')) || [
      { id: '1', username: 'admin', password: 'admin123', role: 'admin', tenant: 'MASTER', display_name: 'Administrator', unit_wilayah: 'Kota', kecamatan: '-', kelurahan: '-' },
      { id: '2', username: 'tebet', password: 'tebet123', role: 'user', tenant: 'Tebet', display_name: 'Operator Tebet', unit_wilayah: 'Kecamatan', kecamatan: 'Tebet', kelurahan: '-' }
    ];

    let serviceMapping = isSupabaseActive ? {} : JSON.parse(localStorage.getItem('sq_services')) || {
      "Perizinan OSS": "OSS", "Perizinan Reklame": "RKL", "Perizinan IMB/PBG": "IMB"
    };

    const wilayahData = {
      "Kebayoran Baru": ["Selong", "Gunung", "Kramat Pela", "Gandaria Utara", "Cipete Utara", "Pulo", "Melawai", "Petogogan"],
      "Kebayoran Lama": ["Grogol Utara", "Grogol Selatan", "Cipulir", "Kebayoran Lama Utara", "Kebayoran Lama Selatan", "Pondok Pinang"],
      "Cilandak": ["Cipete Selatan", "Gandaria Selatan", "Cilandak Barat", "Lebak Bulus", "Pondok Labu"],
      "Pasar Minggu": ["Pejaten Barat", "Pejaten Timur", "Pasar Minggu", "Kebagusan", "Jati Padang", "Ragunan"],
      "Jagakarsa": ["Tanjung Barat", "Lenteng Agung", "Jagakarsa", "Ciganjur", "Srengseng Sawah"],
      "Pancoran": ["Kalibata", "Rawa Jati", "Duren Tiga", "Cikoko", "Pengadegan"],
      "Tebet": ["Tebet Barat", "Tebet Timur", "Kebon Baru", "Bukit Duri", "Manggarai"],
      "Setiabudi": ["Setiabudi", "Karet", "Karet Semanggi", "Kuningan Timur", "Menteng Atas"],
      "Mampang Prapatan": ["Kuningan Barat", "Pela Mampang", "Bangka", "Tegal Parang"],
      "Pesanggrahan": ["Ulujami", "Petukangan Utara", "Petukangan Selatan", "Pesanggrahan", "Bintaro"]
    };

    // --- ADAPTER SUPABASE / LOKAL ---
    async function apiFetchAll() {
      if (isSupabaseActive) {
        try {
          // Fetch Queues
          const { data: qData, error: qErr } = await supabaseClient.from('queues').select('*').order('timestamp', { ascending: true });
          if (!qErr) queueDatabase = qData || [];

          // Fetch Users
          const { data: uData, error: uErr } = await supabaseClient.from('users').select('*');
          if (!uErr) usersDatabase = uData || [];

          // Fetch Services
          const { data: sData, error: sErr } = await supabaseClient.from('services').select('*');
          if (!sErr && sData) {
            serviceMapping = {};
            sData.forEach(s => serviceMapping[s.name] = s.prefix);
          }
        } catch (e) {
          console.error("Supabase Error:", e);
        }
      } else {
        queueDatabase = JSON.parse(localStorage.getItem('smartqueue_db')) || [];
      }
      refreshActiveViews();
    }

    async function apiAddQueue(q) {
      if (isSupabaseActive) {
        const { data, error } = await supabaseClient.from('queues').insert([q]).select();
        if (!error && data) return data[0];
        return null;
      } else {
        q.id = Date.now().toString(); // Generate local ID
        queueDatabase.push(q);
        localStorage.setItem('smartqueue_db', JSON.stringify(queueDatabase));
        refreshActiveViews();
        return q;
      }
    }

    async function apiUpdateQueue(id, updates) {
      if (isSupabaseActive) {
        await supabaseClient.from('queues').update(updates).eq('id', id);
      } else {
        const idx = queueDatabase.findIndex(q => q.id === id);
        if (idx !== -1) queueDatabase[idx] = { ...queueDatabase[idx], ...updates };
        localStorage.setItem('smartqueue_db', JSON.stringify(queueDatabase));
        refreshActiveViews();
      }
    }

    // --- INISIALISASI ---
    window.addEventListener('DOMContentLoaded', () => {
      lucide.createIcons();
      apiFetchAll();

      if (isSupabaseActive) {
        // Realtime Subscription Supabase
        supabaseClient.channel('custom-all-channel')
          .on('postgres_changes', { event: '*', schema: 'public', table: 'queues' }, payload => {
            apiFetchAll(); // Sinkronisasi saat ada perubahan di database
          })
          .subscribe();
      }
    });

    // Waktu & Jam Realtime
    setInterval(() => {
      const now = new Date();
      document.getElementById('live-date').textContent = now.toLocaleDateString('id-ID', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
      document.getElementById('live-time').textContent = now.toLocaleTimeString('id-ID') + ' WIB';
    }, 1000);

    // --- UI HELPERS ---
    function showToast(message, type = 'info') {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      const colors = type === 'success' ? 'bg-white border-emerald-200 text-emerald-800' 
                   : type === 'error' ? 'bg-white border-red-200 text-red-800' 
                   : 'bg-white border-blue-200 text-blue-800';
      toast.className = `px-4 py-3 rounded-2xl border shadow-lg ${colors} font-semibold text-xs transition-all duration-300`;
      toast.textContent = message;
      container.appendChild(toast);
      setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 3000);
    }

    function refreshActiveViews() {
      if (currentView === 'admin') updateAdminView();
      if (currentView === 'monitor') renderMonitorView();
      if (currentView === 'report') renderReportView();
    }

    function switchView(viewName) {
      if ((viewName === 'admin' || viewName === 'report') && !currentUser) {
        openLoginModal();
        return;
      }
      currentView = viewName;
      ['portal', 'register', 'monitor', 'admin', 'report'].forEach(v => document.getElementById(`view-${v}`).classList.add('hidden'));
      document.getElementById(`view-${viewName}`).classList.remove('hidden');
      
      if (viewName === 'admin') {
        const usersTab = document.getElementById('tab-users');
        if (currentUser.role === 'admin') usersTab.classList.remove('hidden');
        else { usersTab.classList.add('hidden'); if(currentAdminTab === 'users') switchAdminTab('panggilan'); }
        updateAdminView();
      }
      if (viewName === 'monitor') renderMonitorView();
      if (viewName === 'report') renderReportView();
      if (viewName === 'register') { renderPurposeDropdown(); renderKecamatanDropdown(); }
      lucide.createIcons();
    }

    function switchAdminTab(tabName) {
      if (tabName === 'users' && currentUser.role !== 'admin') {
        showToast("Akses Ditolak!", "error"); return;
      }
      currentAdminTab = tabName;
      ['panggilan', 'layanan', 'users'].forEach(t => {
        const btn = document.getElementById(`tab-${t}`);
        const content = document.getElementById(`content-admin-${t}`);
        if (t === tabName) {
          btn.className = "border-b-2 border-blue-600 py-3 px-1 text-sm font-bold text-blue-600";
          content.classList.remove('hidden');
        } else {
          btn.className = "border-b-2 border-transparent py-3 px-1 text-sm font-semibold text-slate-500 hover:text-slate-800";
          content.classList.add('hidden');
        }
      });
      if (tabName === 'users') { renderUsersList(); renderUserCreationDropdowns(); }
      lucide.createIcons();
    }

    // --- REGISTRASI ---
    function renderKecamatanDropdown() {
      const select = document.getElementById('reg-kecamatan');
      select.innerHTML = '<option value="">-- Pilih Kecamatan --</option>';
      Object.keys(wilayahData).forEach(k => select.innerHTML += `<option value="${k}">${k}</option>`);
    }

    function handleUnitWilayahChange() {
      const unit = document.getElementById('reg-unit-wilayah').value;
      document.getElementById('wilayah-container').classList.toggle('hidden', unit === 'Kota' || !unit);
      document.getElementById('kecamatan-box').classList.toggle('hidden', unit === 'Kota' || !unit);
      document.getElementById('kelurahan-box').classList.toggle('hidden', unit !== 'Kelurahan');
    }

    function handleKecamatanChange() {
      const kec = document.getElementById('reg-kecamatan').value;
      const kelSelect = document.getElementById('reg-kelurahan');
      kelSelect.innerHTML = '<option value="">-- Pilih Kelurahan --</option>';
      if (kec && wilayahData[kec]) {
        kelSelect.disabled = false;
        wilayahData[kec].forEach(kel => kelSelect.innerHTML += `<option value="${kel}">${kel}</option>`);
      } else { kelSelect.disabled = true; }
    }

    function renderPurposeDropdown() {
      const select = document.getElementById('reg-purpose');
      select.innerHTML = '<option value="">-- Pilih Layanan --</option>';
      Object.keys(serviceMapping).forEach(p => select.innerHTML += `<option value="${p}">${p}</option>`);
    }

    async function handleRegister(e) {
      e.preventDefault();
      
      const btn = document.getElementById('btn-register');
      btn.disabled = true;
      btn.innerHTML = `<i data-lucide="loader-2" class="w-5 h-5 animate-spin"></i> Memproses...`;
      lucide.createIcons();

      const name = document.getElementById('reg-name').value;
      const purpose = document.getElementById('reg-purpose').value;
      const prefix = serviceMapping[purpose] || "ANT";
      
      // Ambil count yang relevan
      const counts = queueDatabase.filter(q => q.purpose === purpose || q.queue_number?.startsWith(prefix)).length;
      const qNum = `${prefix}-${String(counts + 1).padStart(3, '0')}`;
      
      const newQueue = {
        queue_number: qNum,
        timestamp: new Date().toISOString(),
        name: name,
        phone: document.getElementById('reg-phone').value,
        unit_wilayah: document.getElementById('reg-unit-wilayah').value,
        kecamatan: document.getElementById('reg-kecamatan').value || "Tingkat Kota",
        kelurahan: document.getElementById('reg-kelurahan').value || "-",
        address_detail: document.getElementById('reg-address-detail').value,
        purpose: purpose,
        status: "Menunggu",
        counter: ""
      };

      await apiAddQueue(newQueue);
      
      btn.disabled = false;
      btn.innerHTML = `<i data-lucide="printer" class="w-5 h-5"></i> Cetak Nomor Antrian`;
      lucide.createIcons();
      showToast(`Nomor antrian Anda: ${qNum}`, "success");
      document.getElementById('queue-form').reset();
      handleUnitWilayahChange();
      printTicket(newQueue);
      switchView('portal');
    }

    function printTicket(q) {
      const w = window.open('', '_blank', 'width=350,height=500');
      if (!w) return showToast("Popup diblokir.", "info");
      w.document.write(`
        <html><head><title>Tiket Antrian</title>
        <style>body{font-family:monospace;text-align:center;padding:20px;} h1{font-size:48px;margin:20px 0;} .line{border-top:1px dashed #000;margin:15px 0;}</style>
        </head><body>
          <h2>SmartQueue Selatan</h2><div class="line"></div>
          <h1>${q.queue_number}</h1>
          <p><strong>${q.name}</strong></p><p>${q.purpose}</p><p>${q.kecamatan}</p>
          <div class="line"></div><p style="font-size:11px">${new Date(q.timestamp).toLocaleString('id-ID')}</p>
          <script>setTimeout(() => { window.print(); window.close(); }, 500);<\/script>
        </body></html>
      `);
    }

    // --- PANEL ADMIN & OPERATOR ---
    function updateAdminView() {
      if (!currentUser) return;
      
      document.getElementById('op-info-name').textContent = currentUser.display_name;
      document.getElementById('op-info-level').textContent = currentUser.unit_wilayah;
      
      let wKerja = 'Kota';
      if (currentUser.unit_wilayah === 'Kecamatan') wKerja = `Kec. ${currentUser.kecamatan}`;
      if (currentUser.unit_wilayah === 'Kelurahan') wKerja = `Kel. ${currentUser.kelurahan} (${currentUser.kecamatan})`;
      if (currentUser.role === 'admin') wKerja = 'MASTER (Semua Wilayah)';
      document.getElementById('op-info-area').textContent = wKerja;

      document.getElementById('admin-role-badge').textContent = currentUser.role === 'admin' ? 'Admin' : 'Petugas';
      document.getElementById('admin-tenant-info').textContent = `Wilayah Operasional: ${wKerja}`;
      if (document.getElementById('admin-table-title-area')) {
        document.getElementById('admin-table-title-area').textContent = `Daftar Antrian Sesuai Wilayah Kerja Anda (${wKerja})`;
      }

      const counter = document.getElementById('admin-select-counter').value;
      const activeCall = queueDatabase.find(q => q.status === "Dipanggil" && q.counter === counter);
      
      if (activeCall) {
        document.getElementById('admin-current-num').textContent = activeCall.queue_number;
        document.getElementById('admin-current-purpose').textContent = `${activeCall.name} - ${activeCall.purpose}`;
      } else {
        document.getElementById('admin-current-num').textContent = "---";
        document.getElementById('admin-current-purpose').textContent = "Belum ada panggilan";
      }

      const tableBody = document.getElementById('admin-table-body');
      tableBody.innerHTML = '';
      
      const filtered = queueDatabase.filter(q => {
        if (!q) return false;
        if (currentUser.role === 'admin') return true;
        if (currentUser.unit_wilayah === 'Kota') return q.unit_wilayah === 'Kota';
        if (currentUser.unit_wilayah === 'Kecamatan') return q.kecamatan === currentUser.kecamatan;
        if (currentUser.unit_wilayah === 'Kelurahan') return q.kelurahan === currentUser.kelurahan;
        return false;
      });

      document.getElementById('admin-queue-count').textContent = filtered.length;

      if (filtered.length === 0) {
        tableBody.innerHTML = `<tr><td colspan="6" class="p-6 text-center text-xs text-slate-400">Tidak ada antrean dalam wilayah kerja Anda</td></tr>`;
      } else {
        filtered.forEach((q) => {
          const btn = q.status === 'Menunggu' 
            ? `<button onclick="callSpecificQueue('${q.id}')" class="bg-emerald-500 hover:bg-emerald-600 text-white font-bold px-3 py-1.5 rounded-lg text-xs">Panggil</button>`
            : `<span class="text-xs text-slate-400 font-bold">${q.status} (${q.counter})</span>`;
          const tag = q.unit_wilayah === 'Kelurahan' ? q.kelurahan : (q.unit_wilayah === 'Kecamatan' ? q.kecamatan : 'Kota');

          tableBody.innerHTML += `
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="p-3 font-semibold font-numeric text-slate-900">${q.queue_number}</td>
              <td class="p-3 font-medium">${q.name}</td><td class="p-3 text-xs text-slate-500">${q.purpose}</td>
              <td class="p-3"><span class="px-2 py-0.5 rounded text-[10px] font-bold bg-slate-100 text-slate-600">${tag}</span></td>
              <td class="p-3"><span class="px-2 py-1 rounded-full text-[10px] font-bold ${q.status === 'Menunggu' ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700'}">${q.status}</span></td>
              <td class="p-3 text-right">${btn}</td>
            </tr>`;
        });
      }

      // Render Layanan
      const sList = document.getElementById('admin-services-list');
      sList.innerHTML = '';
      Object.keys(serviceMapping).forEach(key => {
        sList.innerHTML += `
          <div class="flex justify-between items-center p-2.5 bg-slate-50 rounded-xl border border-slate-100">
            <div><p class="font-bold text-xs text-slate-800">${key}</p><span class="text-[9px] bg-slate-200 text-slate-600 px-1.5 py-0.5 rounded font-mono font-bold">${serviceMapping[key]}</span></div>
            <button onclick="removeService('${key}')" class="text-red-500 hover:text-red-700 p-1"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
          </div>`;
      });
      lucide.createIcons();
    }

    async function callNextQueue() {
      const counter = document.getElementById('admin-select-counter').value;
      const nextQueue = queueDatabase.find(q => {
        if (!q || q.status !== "Menunggu") return false;
        if (currentUser.role === 'admin') return true;
        if (currentUser.unit_wilayah === 'Kota') return q.unit_wilayah === 'Kota';
        if (currentUser.unit_wilayah === 'Kecamatan') return q.kecamatan === currentUser.kecamatan;
        if (currentUser.unit_wilayah === 'Kelurahan') return q.kelurahan === currentUser.kelurahan;
        return false;
      });

      if (!nextQueue) return showToast("Semua antrean selesai!", "info");

      // Selesaikan antrean lama di loket ini
      const activeCalls = queueDatabase.filter(q => q.counter === counter && q.status === "Dipanggil");
      for (const call of activeCalls) {
        await apiUpdateQueue(call.id, { status: "Selesai" });
      }

      await apiUpdateQueue(nextQueue.id, { status: "Dipanggil", counter: counter });
      showToast(`Memanggil nomor ${nextQueue.queue_number}`, "success");
    }

    async function callSpecificQueue(id) {
      const counter = document.getElementById('admin-select-counter').value;
      const target = queueDatabase.find(q => q.id === id);
      if (!target) return;

      const activeCalls = queueDatabase.filter(q => q.counter === counter && q.status === "Dipanggil");
      for (const call of activeCalls) {
        await apiUpdateQueue(call.id, { status: "Selesai" });
      }

      await apiUpdateQueue(target.id, { status: "Dipanggil", counter: counter });
      showToast(`Memanggil nomor ${target.queue_number}`, "success");
    }

    function recallCurrentQueue() {
      const counter = document.getElementById('admin-select-counter').value;
      const active = queueDatabase.find(q => q.status === "Dipanggil" && q.counter === counter);
      if (active) showToast(`Memanggil ulang nomor ${active.queue_number}`, "info");
      else showToast("Tidak ada antrean aktif", "error");
    }

    // --- MANAJEMEN PENGGUNA (SUPABASE) ---
    function renderUserCreationDropdowns() {
      const uKec = document.getElementById('u-kecamatan');
      uKec.innerHTML = '<option value="">-- Pilih Kecamatan --</option>';
      Object.keys(wilayahData).forEach(k => uKec.innerHTML += `<option value="${k}">${k}</option>`);
    }

    function handleUserWilayahChange() {
      const unit = document.getElementById('u-unit-wilayah').value;
      document.getElementById('u-location-box').classList.toggle('hidden', unit === 'Kota');
      document.getElementById('u-kecamatan-box').classList.toggle('hidden', unit === 'Kota');
      document.getElementById('u-kelurahan-box').classList.toggle('hidden', unit !== 'Kelurahan');
    }

    function handleUserKecamatanChange() {
      const kec = document.getElementById('u-kecamatan').value;
      const kelSelect = document.getElementById('u-kelurahan');
      kelSelect.innerHTML = '<option value="">-- Pilih Kelurahan --</option>';
      if (kec && wilayahData[kec]) wilayahData[kec].forEach(kel => kelSelect.innerHTML += `<option value="${kel}">${kel}</option>`);
    }

    async function handleCreateUser(e) {
      e.preventDefault();
      if (currentUser.role !== 'admin') return showToast("Akses Ditolak!", "error");

      const u = {
        display_name: document.getElementById('u-display-name').value.trim(),
        username: document.getElementById('u-username').value.trim().toLowerCase(),
        password: document.getElementById('u-password').value,
        unit_wilayah: document.getElementById('u-unit-wilayah').value,
        kecamatan: document.getElementById('u-kecamatan').value || '-',
        kelurahan: document.getElementById('u-kelurahan').value || '-',
        role: 'user',
        tenant: document.getElementById('u-unit-wilayah').value === 'Kota' ? 'Kota' : (document.getElementById('u-unit-wilayah').value === 'Kecamatan' ? document.getElementById('u-kecamatan').value : document.getElementById('u-kelurahan').value)
      };

      if (usersDatabase.find(x => x.username === u.username)) return showToast("Username sudah digunakan!", "error");

      if (isSupabaseActive) {
        await supabaseClient.from('users').insert([u]);
        apiFetchAll(); // Refetch Data
      } else {
        u.id = Date.now().toString();
        usersDatabase.push(u);
        localStorage.setItem('sq_users', JSON.stringify(usersDatabase));
        renderUsersList();
      }

      showToast(`Petugas ${u.display_name} berhasil didaftarkan!`, "success");
      e.target.reset();
      handleUserWilayahChange();
    }

    function renderUsersList() {
      const tbody = document.getElementById('users-table-body');
      tbody.innerHTML = '';
      usersDatabase.forEach(u => {
        let wilayah = 'Seluruh Kota (MASTER)';
        if (u.unit_wilayah === 'Kecamatan') wilayah = `Kecamatan ${u.kecamatan}`;
        if (u.unit_wilayah === 'Kelurahan') wilayah = `Kelurahan ${u.kelurahan} (${u.kecamatan})`;

        const isAdmin = u.role === 'admin';
        const delBtn = isAdmin ? `<span class="text-slate-400 italic text-[10px]">Sistem</span>`
          : `<button onclick="deleteUser('${u.id}')" class="bg-red-100 hover:bg-red-200 text-red-700 p-1.5 rounded-lg"><i data-lucide="trash-2" class="w-4 h-4"></i></button>`;

        tbody.innerHTML += `
          <tr class="hover:bg-slate-50">
            <td class="p-3 font-bold text-slate-800">${u.display_name}</td>
            <td class="p-3 font-mono text-slate-500">${u.username}</td>
            <td class="p-3"><span class="px-2 py-0.5 rounded text-[10px] font-bold ${isAdmin ? 'bg-indigo-100 text-indigo-700' : 'bg-emerald-100 text-emerald-700'}">${u.role.toUpperCase()}</span></td>
            <td class="p-3 text-slate-600 font-medium">${wilayah}</td>
            <td class="p-3 text-right">${delBtn}</td>
          </tr>`;
      });
      lucide.createIcons();
    }

    async function deleteUser(id) {
      if (isSupabaseActive) {
        await supabaseClient.from('users').delete().eq('id', id);
        apiFetchAll();
      } else {
        usersDatabase = usersDatabase.filter(u => u.id !== id);
        localStorage.setItem('sq_users', JSON.stringify(usersDatabase));
        renderUsersList();
      }
      showToast("Petugas berhasil dihapus", "info");
    }

    // --- MANAJEMEN LAYANAN ---
    async function handleAddService(e) {
      e.preventDefault();
      const s = {
        name: document.getElementById('new-service-input').value.trim(),
        prefix: document.getElementById('new-service-prefix').value.trim().toUpperCase()
      };

      if (serviceMapping[s.name]) return showToast("Layanan tersebut sudah ada!", "error");

      if (isSupabaseActive) {
        await supabaseClient.from('services').insert([s]);
        apiFetchAll();
      } else {
        serviceMapping[s.name] = s.prefix;
        localStorage.setItem('sq_services', JSON.stringify(serviceMapping));
        updateAdminView();
      }
      e.target.reset();
      showToast("Layanan ditambahkan!", "success");
    }

    async function removeService(name) {
      if (isSupabaseActive) {
        await supabaseClient.from('services').delete().eq('name', name);
        apiFetchAll();
      } else {
        delete serviceMapping[name];
        localStorage.setItem('sq_services', JSON.stringify(serviceMapping));
        updateAdminView();
      }
      showToast("Layanan dihapus", "info");
    }

    // --- MONITOR VIEW ---
    function renderMonitorView() {
      const l1 = queueDatabase.find(q => q.status === 'Dipanggil' && q.counter === 'Loket 1');
      const l2 = queueDatabase.find(q => q.status === 'Dipanggil' && q.counter === 'Loket 2');
      const l3 = queueDatabase.find(q => q.status === 'Dipanggil' && q.counter === 'Loket 3');

      document.getElementById('mon-num-l1').textContent = l1 ? l1.queue_number : '--';
      document.getElementById('mon-purpose-l1').textContent = l1 ? l1.name : 'Kosong';
      document.getElementById('mon-num-l2').textContent = l2 ? l2.queue_number : '--';
      document.getElementById('mon-purpose-l2').textContent = l2 ? l2.name : 'Kosong';
      document.getElementById('mon-num-l3').textContent = l3 ? l3.queue_number : '--';
      document.getElementById('mon-purpose-l3').textContent = l3 ? l3.name : 'Kosong';

      const lastActive = [...queueDatabase].filter(q => q.status === 'Dipanggil').sort((a, b) => b.timestamp.localeCompare(a.timestamp))[0];
      if (lastActive) {
        document.getElementById('mon-current-num').textContent = lastActive.queue_number;
        document.getElementById('mon-current-purpose').textContent = `${lastActive.name} - ${lastActive.purpose}`;
        document.getElementById('mon-current-counter').textContent = lastActive.counter.replace('Loket ', '');
      } else {
        document.getElementById('mon-current-num').textContent = '---';
        document.getElementById('mon-current-purpose').textContent = '-- Antrian Kosong --';
        document.getElementById('mon-current-counter').textContent = '--';
      }

      const waitingList = queueDatabase.filter(q => q.status === 'Menunggu');
      document.getElementById('mon-total-waiting').textContent = waitingList.length;

      const listContainer = document.getElementById('mon-waiting-list');
      listContainer.innerHTML = '';
      if (waitingList.length === 0) {
        listContainer.innerHTML = `<div class="text-center py-8 text-slate-400 text-xs">Tidak ada antrean dalam daftar tunggu</div>`;
      } else {
        waitingList.forEach(q => {
          let loc = q.unit_wilayah === 'Kelurahan' ? q.kelurahan : (q.unit_wilayah === 'Kecamatan' ? q.kecamatan : 'Kota');
          listContainer.innerHTML += `
            <div class="flex items-center justify-between p-3 bg-slate-50 rounded-2xl border border-slate-200">
              <div class="flex items-center space-x-3">
                <span class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 font-extrabold flex items-center justify-center font-numeric text-xs">${q.queue_number}</span>
                <div><h5 class="text-xs font-bold text-slate-800">${q.name}</h5><p class="text-[10px] text-slate-400">${q.purpose}</p></div>
              </div>
              <span class="text-[10px] font-bold text-slate-500 bg-slate-200 px-2.5 py-1 rounded-full">${loc}</span>
            </div>`;
        });
      }
    }

    // --- LAPORAN & REPORT VIEW ---
    function renderReportView() {
      if (!currentUser) return;
      const filterCont = document.getElementById('report-filter-container');
      const selFilter = document.getElementById('report-user-filter');

      if (currentUser.role === 'admin') {
        filterCont.classList.remove('hidden');
        const val = selFilter.value || "SEMUA";
        selFilter.innerHTML = '<option value="SEMUA">Semua Wilayah (MASTER)</option><option value="KOTA">Tingkat Kota saja</option>';
        usersDatabase.forEach(u => {
          if (u.role !== 'admin') {
            let lbl = `${u.display_name} - ${u.unit_wilayah}`;
            if (u.unit_wilayah === 'Kecamatan') lbl += ` (${u.kecamatan})`;
            if (u.unit_wilayah === 'Kelurahan') lbl += ` (${u.kelurahan})`;
            selFilter.innerHTML += `<option value="${u.username}">${lbl}</option>`;
          }
        });
        selFilter.value = val;
      } else filterCont.classList.add('hidden');

      let db = [...queueDatabase];
      const activeFilt = selFilter.value || "SEMUA";

      if (currentUser.role !== 'admin') {
        db = queueDatabase.filter(q => {
          if (!q) return false;
          if (currentUser.unit_wilayah === 'Kota') return q.unit_wilayah === 'Kota';
          if (currentUser.unit_wilayah === 'Kecamatan') return q.kecamatan === currentUser.kecamatan;
          if (currentUser.unit_wilayah === 'Kelurahan') return q.kelurahan === currentUser.kelurahan;
          return false;
        });
      } else {
        if (activeFilt === 'KOTA') db = queueDatabase.filter(q => q && q.unit_wilayah === 'Kota');
        else if (activeFilt !== 'SEMUA') {
          const mUser = usersDatabase.find(u => u.username === activeFilt);
          if (mUser) {
            db = queueDatabase.filter(q => {
              if (mUser.unit_wilayah === 'Kota') return q.unit_wilayah === 'Kota';
              if (mUser.unit_wilayah === 'Kecamatan') return q.kecamatan === mUser.kecamatan;
              if (mUser.unit_wilayah === 'Kelurahan') return q.kelurahan === mUser.kelurahan;
              return false;
            });
          }
        }
      }

      document.getElementById('card-report-kota').classList.toggle('hidden', currentUser.role !== 'admin' && currentUser.unit_wilayah !== 'Kota');
      document.getElementById('card-report-kecamatan').classList.toggle('hidden', currentUser.role !== 'admin' && currentUser.unit_wilayah !== 'Kecamatan');
      document.getElementById('card-report-kelurahan').classList.toggle('hidden', currentUser.role !== 'admin' && currentUser.unit_wilayah !== 'Kelurahan');

      document.getElementById('rep-stat-total').textContent = db.length;
      document.getElementById('rep-stat-served').textContent = db.filter(q => q && (q.status === 'Selesai' || q.status === 'Dipanggil')).length;
      document.getElementById('rep-stat-waiting').textContent = db.filter(q => q && q.status === 'Menunggu').length;

      const regCounts = {};
      db.forEach(q => { if (q && q.kecamatan && q.kecamatan !== 'Tingkat Kota') regCounts[q.kecamatan] = (regCounts[q.kecamatan] || 0) + 1; });
      let peak = "-", mx = 0;
      Object.keys(regCounts).forEach(r => { if (regCounts[r] > mx) { mx = regCounts[r]; peak = r; } });
      document.getElementById('rep-stat-peak').textContent = peak === '-' ? '-' : `${peak} (${mx})`;

      renderCharts(regCounts, db);
      renderMultiLevelReport(db);
      renderLogTable(db);
    }

    function renderLogTable(db) {
      const tbody = document.getElementById('report-table-body');
      tbody.innerHTML = '';
      if (db.length === 0) return tbody.innerHTML = `<tr><td colspan="8" class="p-6 text-center text-xs text-slate-400">Tidak ada data</td></tr>`;
      
      [...db].reverse().forEach(q => {
        tbody.innerHTML += `
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="p-3 font-bold font-numeric text-slate-900">${q.queue_number}</td>
            <td class="p-3 text-xs text-slate-400">${new Date(q.timestamp).toLocaleTimeString('id-ID')}</td>
            <td class="p-3 font-semibold">${q.name}</td>
            <td class="p-3"><span class="px-2 py-0.5 rounded text-[10px] font-bold bg-slate-100 text-slate-600">${q.unit_wilayah}</span></td>
            <td class="p-3 text-slate-500 font-medium">${q.kecamatan}</td>
            <td class="p-3 text-slate-500 font-medium">${q.kelurahan}</td>
            <td class="p-3 text-xs">${q.purpose}</td>
            <td class="p-3"><span class="px-2 py-0.5 rounded-full text-[10px] font-bold ${q.status === 'Menunggu' ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700'}">${q.status}</span></td>
          </tr>`;
      });
    }

    function renderMultiLevelReport(db) {
      // 1. Kota
      const kq = db.filter(q => q && q.unit_wilayah === 'Kota');
      const ks = kq.filter(q => q.status === 'Selesai' || q.status === 'Dipanggil').length;
      const kp = kq.length > 0 ? Math.round((ks / kq.length) * 100) : 0;
      document.getElementById('kota-report-list').innerHTML = `
        <div class="p-4 bg-slate-50 rounded-2xl border">
          <h5 class="font-bold text-slate-800 text-sm">Sekretariat Tingkat Kota</h5>
          <div class="flex justify-between text-xs text-slate-500 mt-2"><span>Total: <strong>${kq.length}</strong></span><span>Selesai: <strong>${ks}</strong></span></div>
          <div class="w-full bg-slate-200 rounded-full h-2 mt-2"><div class="bg-blue-600 h-2 rounded-full" style="width: ${kp}%"></div></div>
        </div>`;

      // 2. Kecamatan
      const kC = document.getElementById('kecamatan-report-list'); kC.innerHTML = '';
      const cStat = {};
      db.forEach(q => {
        if (q && q.kecamatan && q.kecamatan !== 'Tingkat Kota') {
          if (!cStat[q.kecamatan]) cStat[q.kecamatan] = { t: 0, s: 0 };
          cStat[q.kecamatan].t += 1;
          if (q.status === 'Selesai' || q.status === 'Dipanggil') cStat[q.kecamatan].s += 1;
        }
      });
      Object.keys(cStat).forEach(k => {
        const p = Math.round((cStat[k].s / cStat[k].t) * 100);
        kC.innerHTML += `<div class="p-3 bg-slate-50 rounded-xl border border-slate-100"><div class="flex justify-between font-bold text-xs text-slate-700"><span>Kec. ${k}</span><span>${cStat[k].t} Antrean</span></div><div class="w-full bg-slate-200 rounded-full h-1.5 mt-2"><div class="bg-indigo-600 h-1.5 rounded-full" style="width: ${p}%"></div></div></div>`;
      });

      // 3. Kelurahan
      const klC = document.getElementById('kelurahan-report-list'); klC.innerHTML = '';
      const klStat = {};
      db.forEach(q => {
        if (q && q.kelurahan && q.kelurahan !== '-') {
          if (!klStat[q.kelurahan]) klStat[q.kelurahan] = { t: 0, s: 0, k: q.kecamatan };
          klStat[q.kelurahan].t += 1;
          if (q.status === 'Selesai' || q.status === 'Dipanggil') klStat[q.kelurahan].s += 1;
        }
      });
      Object.keys(klStat).forEach(k => {
        const p = Math.round((klStat[k].s / klStat[k].t) * 100);
        klC.innerHTML += `<div class="p-3 bg-slate-50 rounded-xl border border-slate-100"><div class="flex justify-between font-bold text-xs text-slate-700"><span>Kel. ${k}</span><span>${klStat[k].t} Antrean</span></div><div class="w-full bg-slate-200 rounded-full h-1.5 mt-1.5"><div class="bg-teal-500 h-1.5 rounded-full" style="width: ${p}%"></div></div></div>`;
      });
    }

    function renderCharts(regCounts, db) {
      const pCounts = {};
      db.forEach(q => { if (q && q.purpose) pCounts[q.purpose] = (pCounts[q.purpose] || 0) + 1; });

      if (purposeChartInstance) purposeChartInstance.destroy();
      purposeChartInstance = new Chart(document.getElementById('chart-purposes').getContext('2d'), {
        type: 'doughnut', data: { labels: Object.keys(pCounts), datasets: [{ data: Object.values(pCounts), backgroundColor: ['#2563eb', '#10b981', '#f59e0b', '#6366f1', '#ec4899'] }] },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 10 } } } } }
      });

      if (regionChartInstance) regionChartInstance.destroy();
      regionChartInstance = new Chart(document.getElementById('chart-regions').getContext('2d'), {
        type: 'bar', data: { labels: Object.keys(regCounts), datasets: [{ label: 'Jumlah Pemohon', data: Object.values(regCounts), backgroundColor: '#6366f1' }] },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { precision: 0 } } } }
      });
    }

    function exportToCSV() {
      if (queueDatabase.length === 0) return showToast("Tidak ada data untuk diekspor!", "error");
      let csv = "data:text/csv;charset=utf-8,Timestamp,Nama,Telepon,Tingkat,Kecamatan,Kelurahan,Layanan,Status,Loket\n";
      queueDatabase.forEach(q => { if (q) csv += `"${q.timestamp}","${q.name}","${q.phone}","${q.unit_wilayah}","${q.kecamatan}","${q.kelurahan}","${q.purpose}","${q.status}","${q.counter}"\n`; });
      const link = document.createElement("a"); link.setAttribute("href", encodeURI(csv)); link.setAttribute("download", `Laporan_Antrean_${Date.now()}.csv`);
      document.body.appendChild(link); link.click(); document.body.removeChild(link);
    }

    // --- AUTHENTICATION ---
    function openLoginModal() { document.getElementById('login-modal').classList.remove('hidden'); }
    function closeLoginModal() { document.getElementById('login-modal').classList.add('hidden'); }

    function handleLogin(e) {
      e.preventDefault();
      const u = document.getElementById('login-username').value.trim().toLowerCase();
      const p = document.getElementById('login-password').value;

      const user = usersDatabase.find(x => x.username.toLowerCase() === u && x.password === p);
      if (user) {
        currentUser = user; currentTenant = user.tenant;
        document.getElementById('user-display').textContent = user.display_name;
        document.getElementById('user-info').classList.remove('hidden');
        closeLoginModal(); showToast(`Selamat datang, ${user.display_name}!`, "success");
        switchView('admin');
      } else showToast("Username atau Password salah!", "error");
    }

    function logout() {
      currentUser = null; currentTenant = null;
      document.getElementById('user-info').classList.add('hidden');
      showToast("Anda telah keluar dari sistem.", "info");
      switchView('portal');
    }
  </script>
